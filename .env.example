# Convex
CONVEX_DEPLOYMENT=           # e.g. dev:your-deployment-name (from `npx convex dev`)
NEXT_PUBLIC_CONVEX_URL=      # e.g. https://your-deployment.convex.cloud

# Convex Auth
CONVEX_SITE_URL=             # Your app's public URL (e.g. https://your-app.vercel.app)
JWT_PRIVATE_KEY=             # Generated by Convex Auth during setup
JWKS=                        # Generated by Convex Auth during setup

# Resend (email OTP)
AUTH_RESEND_KEY=             # Your Resend API key (https://resend.com)

# OpenAI
OPENAI_API_KEY=              # Your OpenAI API key (https://platform.openai.com)

# App config (optional)
NEXT_PUBLIC_APP_URL=         # Your deploy URL — used for CORS and OG metadata
NEXT_PUBLIC_APP_NAME=        # Display name in emails (default: "Convex Chatbot Kit")
SYSTEM_PROMPT=               # Custom system prompt for the AI (optional)
OPENAI_MODEL=                # Override model (default: gpt-4o-mini)
AUTH_ALLOWED_EMAILS=         # Comma-separated allowlist, e.g. alice@example.com,bob@example.com
